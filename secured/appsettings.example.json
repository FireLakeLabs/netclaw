{
  "NetClaw": {
    "ProjectRoot": "~/.netclaw",
    "DatabasePath": "~/.netclaw/data/netclaw.db",
    "MountAllowlistPath": "~/.netclaw/mount-allowlist.json",
    "SenderAllowlistPath": "~/.netclaw/sender-allowlist.json",
    "Assistant": {
      "Name": "Andy",
      "HasOwnNumber": false
    },
    "ContainerRuntime": {
      "RuntimeBinary": "podman",
      "HostGatewayName": "host.containers.internal",
      "ProxyBindHostOverride": ""
    },
    "AgentRuntime": {
      "DefaultProvider": "copilot",
      "KeepContainerBoundary": true,
      "CopilotCliPath": "copilot",
      "CopilotConfigDirectory": "~/.netclaw/data/copilot",
      "CopilotLogLevel": "info",
      "CopilotUseStdio": true,
      "CopilotAutoStart": true,
      "CopilotAutoRestart": true,
      "CopilotUseLoggedInUser": false,
      "CopilotClientName": "NetClaw",
      "CopilotModel": "gpt-5",
      "InteractiveIdleTimeout": "00:00:30",
      "CopilotReasoningEffort": "high",
      "CopilotStreaming": true,
      "CopilotEnableInfiniteSessions": true
    },
    "Channels": {
      "PollInterval": "00:00:01",
      "InitialSyncOnStart": true,
      "Terminal": {
        "Enabled": true,
        "ChatJid": "team@jid",
        "Sender": "terminal-user",
        "SenderName": "Terminal User",
        "ChatName": "Terminal Chat",
        "IsGroup": true,
        "OutboundPrefix": "assistant> ",
        "InputPrompt": "you> "
      },
      "ReferenceFile": {
        "Enabled": false,
        "RootDirectory": "~/.netclaw/data/channels/reference-file",
        "ClaimAllChats": true
      },
      "Slack": {
        "Enabled": false,
        "BotToken": "USE_OP_RUN_INSTEAD",
        "AppToken": "USE_OP_RUN_INSTEAD",
        "ApiBaseUrl": "https://slack.com/api",
        "MentionReplacement": "@Andy",
        "WorkingIndicatorText": "Evaluating...",
        "ReplyInThreadByDefault": true
      }
    },
    "MessageLoop": {
      "PollInterval": "00:00:01",
      "Timezone": "UTC"
    },
    "Ipc": {
      "PollInterval": "00:00:02"
    },
    "Scheduler": {
      "PollInterval": "00:00:05"
    },
    "Dashboard": {
      "Enabled": true,
      "Port": 5080,
      "BindAddress": "127.0.0.1"
    },
    "CredentialProxy": {
      "Host": "0.0.0.0",
      "Port": 3001
    }
  }
}
