{
  "NetClaw": {
    "ProjectRoot": "/tmp/netclaw",
    "DatabasePath": "/tmp/netclaw/data/netclaw.db",
    "MountAllowlistPath": "/tmp/netclaw/mount-allowlist.json",
    "SenderAllowlistPath": "/tmp/netclaw/sender-allowlist.json",
    "Assistant": {
      "Name": "Andy",
      "HasOwnNumber": false
    },
    "ContainerRuntime": {
      "RuntimeBinary": "docker",
      "HostGatewayName": "host.docker.internal",
      "ProxyBindHostOverride": "",
      "ImageName": "netclaw-agent:latest",
      "ExecutionTimeout": "00:10:00",
      "MaxOutputBytes": 10485760
    },
    "AgentRuntime": {
      "DefaultProvider": "copilot",
      "CopilotCliPath": "copilot",
      "CopilotConfigDirectory": "/tmp/netclaw/data/copilot",
      "CopilotLogLevel": "info",
      "CopilotUseStdio": true,
      "CopilotAutoStart": true,
      "CopilotAutoRestart": true,
      "CopilotUseLoggedInUser": true,
      "CopilotClientName": "NetClaw",
      "CopilotModel": "gpt-5",
      "InteractiveIdleTimeout": "00:00:30",
      "CopilotReasoningEffort": "high",
      "CopilotStreaming": true,
      "CopilotEnableInfiniteSessions": true
    },
    "Channels": {
      "PollInterval": "00:00:01",
      "InitialSyncOnStart": true,
      "Terminal": {
        "Enabled": true,
        "ChatJid": "team@jid",
        "Sender": "terminal-user",
        "SenderName": "Terminal User",
        "ChatName": "Terminal Chat",
        "IsGroup": true,
        "OutboundPrefix": "assistant> ",
        "InputPrompt": "you> "
      },
      "ReferenceFile": {
        "Enabled": false,
        "RootDirectory": "/tmp/netclaw/data/channels/reference-file",
        "ClaimAllChats": true
      },
      "Slack": {
        "Enabled": false,
        "BotToken": "xoxb-change-me",
        "AppToken": "xapp-change-me",
        "ApiBaseUrl": "https://slack.com/api",
        "MentionReplacement": "@Andy",
        "WorkingIndicatorText": "Evaluating...",
        "ReplyInThreadByDefault": true
      }
    },
    "MessageLoop": {
      "PollInterval": "00:00:01",
      "Timezone": "UTC"
    },
    "Ipc": {
      "PollInterval": "00:00:02"
    },
    "Scheduler": {
      "PollInterval": "00:00:05"
    },
    "CredentialProxy": {
      "Host": "127.0.0.1",
      "Port": 3001,
      "CopilotUpstreamUrl": "https://api.githubcopilot.com",
      "ClaudeUpstreamUrl": "https://api.anthropic.com",
      "AuthMode": "api-key"
    }
  }
}